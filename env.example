# =============================================================================
# LLM TRAINING AGENT SYSTEM — Environment Variables
# =============================================================================
# Zweck: Alle Umgebungsvariablen für das komplette LLM Training Agent System.
#
# ⚠️  NIEMALS in Git committen! Immer in .gitignore eintragen.
#
# Setup:
#   cp .env.example .env
#   echo ".env"              >> .gitignore
#   echo "gcp-agent-key.json" >> .gitignore
# =============================================================================


# -----------------------------------------------------------------------------
# ☁️  GCP
# -----------------------------------------------------------------------------

# Dein GCP Project ID
# Finden: gcloud config get-value project
GCP_PROJECT_ID=

# Billing Account ID
# Finden: gcloud billing accounts list
GCP_BILLING_ACCOUNT=

# GCP Zone (fix)
GCP_ZONE=us-central1-a

# Pfad zum Service Account JSON Key
# Erstellen: IAM & Admin → Service Accounts → Key erstellen
GCP_SERVICE_ACCOUNT_KEY_PATH=./gcp-agent-key.json

# Gleich wie GCP_SERVICE_ACCOUNT_KEY_PATH (wird von Google SDK verwendet)
GOOGLE_APPLICATION_CREDENTIALS=./gcp-agent-key.json


# -----------------------------------------------------------------------------
# 🖥️  VM
# -----------------------------------------------------------------------------

# Name der GCP VM Instanz
VM_INSTANCE_NAME=llm-pretrain-1b

# Machine Type: A100 40GB
VM_MACHINE_TYPE=a2-highgpu-1g

# Temporärer Disk Storage in GB
VM_DISK_SIZE_GB=600


# -----------------------------------------------------------------------------
# 💰  Budget
# -----------------------------------------------------------------------------

# Hard Limit in USD
BUDGET_TOTAL_USD=200

# Warnung bei X% des Budgets
BUDGET_WARN_PERCENT=80

# Training pausieren bei X%
BUDGET_PAUSE_PERCENT=95

# Training stoppen bei X%
BUDGET_STOP_PERCENT=100


# -----------------------------------------------------------------------------
# 🤗  HuggingFace
# -----------------------------------------------------------------------------

# HuggingFace API Token
# Finden: https://huggingface.co/settings/tokens
HF_TOKEN=

# Dein HuggingFace Username
HF_USERNAME=


# -----------------------------------------------------------------------------
# 📊  Weights & Biases
# -----------------------------------------------------------------------------

# wandb API Key
# Finden: https://wandb.ai/settings
WANDB_API_KEY=

# Projektname in wandb (frei wählbar)
WANDB_PROJECT=llm-pretrain-1b


# -----------------------------------------------------------------------------
# 📓  Notion
# -----------------------------------------------------------------------------

# Notion Integration Token
# Erstellen: https://www.notion.so/my-integrations
NOTION_API_KEY=

# Training Journal Page ID
NOTION_TRAINING_JOURNAL_ID=327e5336-9bae-8103-816c-d7be0755ca91

# Roadmap Page ID
NOTION_ROADMAP_PAGE_ID=326e5336-9bae-81d9-adad-eeb0b3b897fe


# -----------------------------------------------------------------------------
# 🔔  Notifications (optional, aber empfohlen)
# -----------------------------------------------------------------------------

# Telegram Bot Token
# Erstellen: @BotFather auf Telegram
TELEGRAM_BOT_TOKEN=

# Deine persönliche Telegram Chat-ID
TELEGRAM_CHAT_ID=


# =============================================================================
# Checklist vor erstem Start
# =============================================================================
# [ ] GCP_PROJECT_ID eingetragen
# [ ] GCP_BILLING_ACCOUNT eingetragen
# [ ] Service Account Key erstellt + Pfad eingetragen
# [ ] HF_TOKEN eingetragen
# [ ] WANDB_API_KEY eingetragen
# [ ] NOTION_API_KEY eingetragen
# [ ] .env in .gitignore eingetragen
# [ ] gcp-agent-key.json in .gitignore eingetragen
# [ ] Telegram Bot erstellt (optional)
# =============================================================================
